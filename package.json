{
  "name": "tundraboard",
  "version": "1.0.0",
  "description": "TundraBoard — Task management and team collaboration API. Starter project for the AI-Native Software Development training programme.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm test"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.24.0",
    "uuid": "^11.1.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^10.0.0",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "prisma": "^6.5.0",
    "vitest": "^3.1.0",
    "supertest": "^7.0.0",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "prettier": "^3.4.0",
    "@vitest/coverage-v8": "^3.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
